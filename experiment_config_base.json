{
  "experiment_type": "optima_intervention_regime",
  "experiment_name": "optima_intervention_regime_base",
  "paper_reference": "Intervention-anchored latent response regime experiment built on the Optima benchmark",
  "paths": {
    "source_data_dir": "data/Swissmetro/demographic_choice_psychometric"
  },
  "intervention_tests": {
    "repeat_randomness_kappa": 1.25,
    "bootstrap_repetitions": 200,
    "utility_equivalent_manipulations": [
      "paraphrase",
      "label_mask",
      "order_randomization"
    ]
  },
  "human_baseline_mnl": {
    "optimizer": "scipy_bfgs"
  },
  "panel_mnl": {
    "optimizer": "scipy_bfgs",
    "maxiter": 500
  },
  "biogeme": {
    "optimization_algorithm": "scipy"
  },
  "salcm": {
    "n_preference_classes": 3,
    "n_scale_classes": 2,
    "optimizer": "scipy_lbfgsb",
    "maxiter": 800,
    "membership_covariates": [
      "model_is_deepseek",
      "semantic_arm",
      "prompt_family_naturalistic",
      "age_30_less",
      "high_education",
      "ScaledIncome",
      "CAR_AVAILABLE",
      "block_complexity_mean"
    ]
  },
  "analysis_v2": {
    "randomness_tolerance_kappa": 1.25,
    "exact_repeat_signature_fields": [
      "model_key",
      "human_id",
      "prompt_arm",
      "task_role",
      "manipulation_type",
      "scenario_id",
      "semantic_labels",
      "option_order",
      "TimePT_scaled",
      "WaitingTimePT_scaled",
      "MarginalCostPT_scaled",
      "TimeCar_scaled",
      "CostCarCHF_scaled",
      "distance_km_scaled"
    ],
    "paired_interventions": [
      "paraphrase",
      "label_mask",
      "order_randomization"
    ],
    "between_block_interventions": [
      "prompt_arm"
    ]
  },
  "torch": {
    "default_device": "cuda_if_available",
    "float_dtype": "float64"
  },
  "n_monte_carlo_draws_biogeme": 32,
  "n_monte_carlo_draws_torch_compare": 32,
  "n_monte_carlo_draws_torch_final": 500,
  "shared_draw_dims": 2,
  "shared_draw_names": [
    "omega_car",
    "omega_env"
  ]
}
